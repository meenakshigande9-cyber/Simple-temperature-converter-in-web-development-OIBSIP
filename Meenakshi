<!DOCTYPE html>
<html>
<head>

    <title>Temperature Converter</title>

    <style>

        body{
            text-align:center;
            font-family:Arial;
            background-color:blue;
            margin-top:50px;
        }

        .box{
            background-color:white;
            width:300px;
            margin:auto;
            padding:30px;
        }

        input, select{
            padding:10px;
            width:200px;
            margin:10px;
        }

        button{
            background-color:red;
            color:white;
            border:none;
            padding:10px 20px;
        }

    </style>

</head>

<body>

    <div class="box">

        <h1>Temperature Converter</h1>

        <input type="number" id="temp" placeholder="Enter Temperature">

        <br>

        <select id="choice">

            <option value="ctof">
                Celsius to Fahrenheit
            </option>

            <option value="ftoc">
                Fahrenheit to Celsius
            </option>

        </select>

        <br>

        <button onclick="convert()">Convert</button>

        <h2 id="result"></h2>

    </div>

    <script>

        function convert(){

            let temp =
            document.getElementById("temp").value;

            let choice =
            document.getElementById("choice").value;

            let answer;

            if(choice=="ctof"){

                answer = (temp * 9/5) + 32;

                document.getElementById("result").innerHTML =
                "Fahrenheit = " + answer;

            }

            else{

                answer = (temp - 32) * 5/9;

                document.getElementById("result").innerHTML =
                "Celsius = " + answer;

            }

        }

    </script>

</body>
</html>
